{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adapter_status.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewer",
    "stage",
    "status",
    "started_at",
    "completed_at",
    "duration_ms",
    "error_class",
    "error_message_redacted",
    "output_file"
  ],
  "properties": {
    "schema_version": { "const": "adapter_status.v1" },
    "reviewer": { "type": "string", "minLength": 1 },
    "stage": { "enum": ["review", "critique"] },
    "status": {
      "enum": [
        "success",
        "skipped",
        "timeout",
        "model_error",
        "schema_error",
        "config_error",
        "internal_error"
      ]
    },
    "started_at": { "type": "string", "minLength": 1 },
    "completed_at": { "type": "string", "minLength": 1 },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "error_class": { "type": ["string", "null"] },
    "error_message_redacted": { "type": ["string", "null"] },
    "output_file": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "raw_finding_count": { "type": "integer", "minimum": 0 },
    "accepted_finding_count": { "type": "integer", "minimum": 0 },
    "dropped_finding_count": { "type": "integer", "minimum": 0 },
    "usable_for_resolution": { "type": "boolean" },
    "effective_config_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
