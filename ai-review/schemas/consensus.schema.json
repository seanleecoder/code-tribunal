{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "consensus.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "project_id",
    "merge_request_iid",
    "head_sha",
    "input_manifest_sha256",
    "successful_reviewers",
    "failed_reviewers",
    "panel_status",
    "groups",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": "consensus.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "merge_request_iid": { "type": "string" },
    "head_sha": { "type": "string" },
    "input_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "successful_reviewers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failed_reviewers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "panel_status": { "enum": ["full", "degraded", "advisory_only", "failed"] },
    "groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/group" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_count",
        "fyi_count",
        "drop_count",
        "block_merge",
        "panel_convergence"
      ],
      "properties": {
        "surface_count": { "type": "integer", "minimum": 0 },
        "fyi_count": { "type": "integer", "minimum": 0 },
        "drop_count": { "type": "integer", "minimum": 0 },
        "block_merge": { "type": "boolean" },
        "panel_convergence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["issue_id_source"],
            "properties": {
              "issue_id_source": { "const": "ambiguous_unassigned" }
            }
          },
          "then": {
            "properties": {
              "issue_id": { "type": "null" },
              "decision": { "const": "fyi" },
              "block_merge": { "const": false }
            }
          },
          "else": {
            "properties": {
              "issue_id": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      ],
      "required": [
        "issue_id",
        "issue_id_source",
        "decision",
        "final_severity",
        "block_merge",
        "human_ack_recommended",
        "category",
        "title",
        "body",
        "body_hash",
        "vote_count",
        "critique_support_count",
        "critique_noise_count",
        "contributing_reviewers",
        "source_finding_ids",
        "candidate_issue_signature_hashes",
        "critique_summary",
        "representative_anchor",
        "all_anchors",
        "match_keys",
        "state_match"
      ],
      "properties": {
        "issue_id": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "issue_id_source": {
          "enum": ["matched_state", "new_signature", "ambiguous_unassigned"]
        },
        "decision": { "enum": ["surface", "fyi", "drop"] },
        "final_severity": { "enum": ["info", "minor", "major", "blocker"] },
        "block_merge": { "type": "boolean" },
        "human_ack_recommended": { "type": "boolean" },
        "category": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "body": { "type": "string" },
        "suggestion": { "type": ["string", "null"] },
        "evidence_by_reviewer": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "critique_disputes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["critic", "rationale"],
            "properties": {
              "critic": { "type": "string", "minLength": 1 },
              "rationale": { "type": "string", "minLength": 1 },
              "adjusted_severity": {
                "type": ["string", "null"],
                "enum": ["info", "minor", "major", "blocker", null]
              }
            }
          }
        },
        "body_hash": { "$ref": "#/$defs/sha256" },
        "vote_count": { "type": "integer", "minimum": 0 },
        "critique_support_count": { "type": "integer", "minimum": 0 },
        "critique_noise_count": { "type": "integer", "minimum": 0 },
        "contributing_reviewers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_finding_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/sha256" }
        },
        "candidate_issue_signature_hashes": {
          "type": "array",
          "items": { "$ref": "#/$defs/sha256" }
        },
        "critique_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["agree", "dispute", "noise", "duplicate"],
          "properties": {
            "agree": { "type": "integer", "minimum": 0 },
            "dispute": { "type": "integer", "minimum": 0 },
            "noise": { "type": "integer", "minimum": 0 },
            "duplicate": { "type": "integer", "minimum": 0 }
          }
        },
        "representative_anchor": { "type": "object" },
        "all_anchors": {
          "type": "array",
          "items": { "type": "object" }
        },
        "match_keys": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path_keys",
            "category",
            "context_hashes",
            "title_fingerprints",
            "symbols"
          ],
          "properties": {
            "path_keys": {
              "type": "array",
              "items": { "type": "string" }
            },
            "category": { "type": "string" },
            "context_hashes": {
              "type": "array",
              "items": { "$ref": "#/$defs/sha256" }
            },
            "title_fingerprints": {
              "type": "array",
              "items": { "$ref": "#/$defs/sha256" }
            },
            "symbols": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "state_match": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "matched_issue_id", "precedence"],
          "properties": {
            "status": { "enum": ["matched", "new", "ambiguous"] },
            "matched_issue_id": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
            "precedence": {
              "type": ["string", "null"],
              "enum": [
                "exact_issue_id",
                "source_finding_id",
                "context_hash",
                "title_anchor",
                "symbol_title",
                null
              ]
            }
          }
        }
      }
    }
  }
}
